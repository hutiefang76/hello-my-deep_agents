# ============================================================
# hello-my-deep_agents · 环境变量模板
# 用法: cp .env.example .env && 填上真实 key
# 红线: .env 已在 .gitignore, 绝不能 commit
# ============================================================

# ----- LLM Provider 选择 -----
# 可选: tongyi (默认, 阿里云 DashScope) | openai_compat | ollama
LLM_PROVIDER=tongyi
LLM_MODEL=qwen-plus
LLM_TEMPERATURE=0.3

# ----- 阿里云通义 DashScope (主路径) -----
# 申请地址: https://bailian.console.aliyun.com/?apiKey=1
DASHSCOPE_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ----- OpenAI 兼容路径 (备选, DashScope OpenAI 兼容模式 / OpenAI 官方 / 任何兼容供应商) -----
# OpenAI 官方:        https://api.openai.com/v1
# DashScope 兼容模式:  https://dashscope.aliyuncs.com/compatible-mode/v1
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
OPENAI_MODEL=qwen-plus

# ----- Ollama 本地路径 (离线 / 省钱场景) -----
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b

# ----- Embedding 模型 (RAG 用) -----
# DashScope 提供的 embedding 模型, 配合 qwen 用最稳
EMBEDDING_PROVIDER=tongyi
EMBEDDING_MODEL=text-embedding-v3
# 备选: 本地 Ollama nomic-embed-text
# EMBEDDING_PROVIDER=ollama
# EMBEDDING_MODEL=nomic-embed-text

# ----- 中间件 (Memory / RAG lab 需要, docker compose 默认值) -----
PGVECTOR_HOST=localhost
PGVECTOR_PORT=5432
PGVECTOR_DATABASE=deepagents
PGVECTOR_USER=deepagents
PGVECTOR_PASSWORD=deepagents123

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# ----- 搜索工具 (Ch3 / Ch4.2.3 用, 可选) -----
# Tavily 搜索: https://tavily.com  (新用户免费 1000 次/月)
TAVILY_API_KEY=tvly-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# SerpAPI 备选: https://serpapi.com
# SERPAPI_API_KEY=

# ----- 可观测性 (可选) -----
# LangSmith: https://smith.langchain.com
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=hello-my-deep_agents

# ----- 日志级别 -----
LOG_LEVEL=INFO
